{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backendcompiler.dev/schema/backend-spec.v1.schema.json",
  "title": "Backend Compiler Specification v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["specVersion", "project", "target", "entities", "features"],
  "properties": {
    "specVersion": {
      "const": "backendcompiler.dev/v1"
    },
    "project": {
      "$ref": "#/$defs/project"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "entities": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/identifier"
      },
      "additionalProperties": {
        "$ref": "#/$defs/entity"
      }
    },
    "features": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "additionalProperties": {
        "type": "object"
      }
    },
    "options": {
      "$ref": "#/$defs/options"
    }
  },
  "$defs": {
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiPrefix": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9/-]*$",
          "maxLength": 32
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 2,
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "database"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "database": {
          "enum": ["postgresql", "mysql", "sqlite"]
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "fields": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/identifier"
          },
          "additionalProperties": {
            "oneOf": [
              { "$ref": "#/$defs/fieldType" },
              { "$ref": "#/$defs/field" }
            ]
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/index"
          }
        }
      }
    },
    "fieldType": {
      "enum": [
        "string",
        "text",
        "integer",
        "decimal",
        "boolean",
        "datetime",
        "date",
        "uuid"
      ]
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "$ref": "#/$defs/fieldType"
        },
        "required": {
          "type": "boolean"
        },
        "unique": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1
        },
        "enum": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          }
        },
        "default": {
          "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }]
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "target"],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "enum": ["belongsTo", "hasOne", "hasMany", "manyToMany"]
        },
        "target": {
          "$ref": "#/$defs/identifier"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/identifier"
          }
        },
        "unique": {
          "type": "boolean"
        }
      }
    }
  }
}
