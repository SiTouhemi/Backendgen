{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backendcompiler.dev/schema/frontend-contract.v1.schema.json",
  "title": "BackendGen Frontend Contract v1",
  "description": "Machine-readable API contract emitted as frontend-contract.json next to every generated backend. It carries only client-facing shape: no internal fields, no secret names or values, no environment values.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "api", "features", "entities", "endpoints", "client"],
  "properties": {
    "schemaVersion": {
      "const": "backendcompiler.dev/frontend-contract/v1"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basePath", "authentication", "organizationContext", "cors"],
      "properties": {
        "basePath": { "type": "string", "pattern": "^/" },
        "authentication": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["scheme", "header", "prefix"],
              "properties": {
                "scheme": { "const": "bearer" },
                "header": { "const": "Authorization" },
                "prefix": { "const": "Bearer" }
              }
            }
          ]
        },
        "organizationContext": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["header", "requiredOnTenantRoutes"],
              "properties": {
                "header": { "const": "X-Organization-Id" },
                "requiredOnTenantRoutes": { "type": "boolean" }
              }
            }
          ]
        },
        "cors": {
          "type": "object",
          "additionalProperties": false,
          "required": ["environmentVariable", "format", "credentials"],
          "properties": {
            "environmentVariable": { "const": "CORS_ORIGINS" },
            "format": { "type": "string" },
            "credentials": { "const": false }
          }
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "fields", "relations"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "fields": {
            "type": "array",
            "items": { "$ref": "#/$defs/field" }
          },
          "relations": {
            "type": "array",
            "items": { "$ref": "#/$defs/relation" }
          }
        }
      }
    },
    "endpoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/endpoint" }
    },
    "client": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["directory", "packageName", "entrypoint", "factory"],
          "properties": {
            "directory": { "const": "client" },
            "packageName": { "type": "string", "minLength": 1 },
            "entrypoint": { "const": "client/src/index.ts" },
            "factory": { "const": "createClient" }
          }
        }
      ]
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required", "readOnly", "enum"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "enum": ["string", "text", "integer", "decimal", "boolean", "datetime", "date", "uuid"]
        },
        "required": { "type": "boolean" },
        "readOnly": { "type": "boolean" },
        "enum": {
          "oneOf": [
            { "type": "null" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "target", "required", "foreignKey"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["belongsTo", "hasOne", "hasMany", "manyToMany"] },
        "target": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "foreignKey": { "type": ["string", "null"] }
      }
    },
    "endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "method", "path", "summary", "auth", "roles", "entity", "operation"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "pattern": "^/" },
        "summary": { "type": "string" },
        "auth": { "enum": ["public", "authenticated"] },
        "roles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "entity": { "type": ["string", "null"] },
        "operation": { "type": "string", "minLength": 1 }
      }
    }
  }
}
